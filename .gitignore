data/raw/
*.xlsx
*.xls
*.csv
!data/external/*.csv

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
venv/
.env

# Jupyter
.ipynb_checkpoints/
*.ipynb_metadata/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Reports (large files)
reports/figures/*.png
reports/figures/*.jpg
!reports/figures/.gitkeep
